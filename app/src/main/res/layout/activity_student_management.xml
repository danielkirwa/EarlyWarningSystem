<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="12dp"
    tools:context=".StudentManagement">


    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Student Management"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:gravity="center"
        android:textColor="#388E3C" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Add Student Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add New Student"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Student Name"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Parent Phone (+254...)"
                android:inputType="phone"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Class/Grade"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sibling (if any):"
                android:textSize="14sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerSibling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Border Zone:"
                android:textSize="14sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerBorderZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnAddStudent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add Student"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="#388E3C"
                android:textColor="#FFFFFF"
                android:elevation="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Search Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Search by Parent Phone"
                android:textSize="14sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <AutoCompleteTextView
                android:id="@+id/autoParentPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Type parent phone..."
                android:inputType="phone"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:layout_marginBottom="12dp"/>

            <!-- Registered Students Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registered Students"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <ListView
                android:id="@+id/lvStudents"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:divider="#E0E0E0"
                android:dividerHeight="1dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>